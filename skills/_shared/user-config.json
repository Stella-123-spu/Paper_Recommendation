    "terminology": [
      {
        "category": "Patient trajectory and temporal modeling",
        "terms": [
          {
            "term": "Patient trajectory modeling",
            "aliases": [
              "patient journey modeling"
            ],
            "summary": "Models repeated visits, events, tests, treatments, and outcomes as a continuously evolving patient process."
          },
          {
            "term": "Longitudinal EHR modeling",
            "aliases": [
              "longitudinal patient modeling"
            ],
            "summary": "Learns representations, predictions, or generations from longitudinal electronic health record sequences."
          },
          {
            "term": "Temporal reasoning",
            "aliases": [
              "time-aware reasoning"
            ],
            "summary": "Explicitly handles event order, time gaps, temporal scales, and causal temporal constraints."
          },
          {
            "term": "Temporal abstraction",
            "aliases": [],
            "summary": "Compresses fine-grained clinical events into higher-level temporal patterns or stage representations."
          },
          {
            "term": "Survival analysis",
            "aliases": [
              "time-to-event modeling"
            ],
            "summary": "Models time-to-event outcomes and censoring, commonly used for clinical risk assessment."
          }
        ]
      },
      {
        "category": "EHR foundation models and patient representation",
        "terms": [
          {
            "term": "EHR foundation model",
            "aliases": [
              "clinical foundation model"
            ],
            "summary": "A general-purpose model pretrained on large-scale electronic health records for transfer to downstream clinical tasks."
          },
          {
            "term": "Patient representation learning",
            "aliases": [
              "patient embedding"
            ],
            "summary": "Learns compact patient-level representations for retrieval, prediction, stratification, and decision support."
          },
          {
            "term": "Self-supervised pretraining",
            "aliases": [
              "self-supervised learning"
            ],
            "summary": "Pretrains general representations on unlabeled or weakly labeled clinical data."
          },
          {
            "term": "Masked modeling",
            "aliases": [
              "masked token modeling",
              "masked event modeling"
            ],
            "summary": "Learns clinical context representations by reconstructing masked events, codes, or text."
          },
          {
            "term": "Clinical retrieval",
            "aliases": [
              "cohort retrieval"
            ],
            "summary": "Retrieves similar patients or case subsets from patient representations, case descriptions, or query criteria."
          }
        ]
      },
      {
        "category": "Clinical prediction and risk stratification",
        "terms": [
          {
            "term": "Risk prediction",
            "aliases": [],
            "summary": "Predicts the probability of future clinical events, complications, or adverse outcomes."
          },
          {
            "term": "Outcome prediction",
            "aliases": [],
            "summary": "Predicts clinical outcomes after treatment or follow-up."
          },
          {
            "term": "Early warning",
            "aliases": [
              "deterioration prediction"
            ],
            "summary": "Provides early warning for high-risk events such as deterioration, sepsis, or death."
          },
          {
            "term": "Readmission prediction",
            "aliases": [],
            "summary": "Predicts a patient’s risk of readmission after discharge."
          },
          {
            "term": "Treatment response modeling",
            "aliases": [],
            "summary": "Predicts efficacy, toxicity, or recovery trajectories under different treatment options."
          }
        ]
      },
      {
        "category": "Clinical LLMs and medical QA",
        "terms": [
          {
            "term": "Clinical LLM",
            "aliases": [
              "medical LLM"
            ],
            "summary": "A large language model for clinical text understanding, question answering, summarization, and decision support."
          },
          {
            "term": "Retrieval-augmented generation",
            "aliases": [
              "RAG"
            ],
            "summary": "Retrieves cases, guidelines, or knowledge before generating answers to reduce hallucination."
          },
          {
            "term": "Instruction tuning",
            "aliases": [],
            "summary": "Fine-tunes a model on task-instruction data to better support clinical QA and task execution."
          },
          {
            "term": "Clinical summarization",
            "aliases": [
              "discharge summary generation"
            ],
            "summary": "Generates structured or free-text summaries from records, tests, and timelines."
          },
          {
            "term": "Grounded medical QA",
            "aliases": [],
            "summary": "Requires answers to be supported by evidence from records, literature, or guidelines."
          }
        ]
      },
      {
        "category": "Multimodal clinical modeling",
        "terms": [
          {
            "term": "Multimodal clinical modeling",
            "aliases": [
              "multimodal patient modeling"
            ],
            "summary": "Jointly models EHR, clinical text, imaging, waveforms, omics, and other data sources."
          },
          {
            "term": "Cross-modal fusion",
            "aliases": [
              "multimodal fusion"
            ],
            "summary": "Aligns and fuses information from different modalities into a unified patient representation."
          },
          {
            "term": "Clinical imaging-language modeling",
            "aliases": [],
            "summary": "Jointly models clinical images with reports, records, or labels."
          },
          {
            "term": "Waveform-EHR fusion",
            "aliases": [],
            "summary": "Fuses monitoring waveforms with structured EHR information to improve temporal prediction."
          }
        ]
      },
      {
        "category": "Causal, intervention, and clinical decision-making",
        "terms": [
          {
            "term": "Causal inference",
            "aliases": [],
            "summary": "Estimates causal relationships between interventions and outcomes from observational clinical data."
          },
          {
            "term": "Counterfactual inference",
            "aliases": [],
            "summary": "Estimates outcomes a patient might have had under alternative interventions."
          },
          {
            "term": "Treatment effect estimation",
            "aliases": [
              "uplift modeling"
            ],
            "summary": "Estimates individualized treatment effects for precision intervention selection."
          },
          {
            "term": "Off-policy evaluation",
            "aliases": [
              "OPE"
            ],
            "summary": "Evaluates the expected effect of a new policy on historical data without deploying it."
          },
          {
            "term": "Clinical decision-making",
            "aliases": [
              "medical decision support"
            ],
            "summary": "Uses models to support diagnosis, triage, management, and treatment planning."
          }
        ]
      },
      {
        "category": "Medical world models and virtual patients",
        "terms": [
          {
            "term": "Medical world model",
            "aliases": [],
            "summary": "Learns latent dynamics of how patient state changes over time and interventions."
          },
          {
            "term": "Virtual patient",
            "aliases": [
              "digital patient twin",
              "patient simulator"
            ],
            "summary": "A patient simulator for disease-course rollout, intervention evaluation, and decision-policy training."
          },
          {
            "term": "Latent dynamics model",
            "aliases": [],
            "summary": "Models disease-state transitions and intervention effects in latent space."
          },
          {
            "term": "Counterfactual rollout",
            "aliases": [],
            "summary": "Simulates future trajectories under different treatment decisions."
          }
        ]
      },
      {
        "category": "Common datasets and benchmarks",
        "terms": [
          {
            "term": "MIMIC-IV",
            "aliases": [
              "MIMIC"
            ],
            "summary": "A widely used large-scale intensive-care electronic health record dataset."
          },
          {
            "term": "eICU",
            "aliases": [],
            "summary": "A multi-center intensive-care electronic health record dataset."
          },
          {
            "term": "PhysioNet",
            "aliases": [],
            "summary": "A data platform containing clinical time series, waveforms, and challenge tasks."
          },
          {
            "term": "UK Biobank",
            "aliases": [],
            "summary": "A large population cohort resource often used for long-term risk and multimodal research."
          }
        ]
      }
    ]
